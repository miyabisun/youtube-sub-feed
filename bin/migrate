#!/usr/bin/env bash
set -euo pipefail

if [ $# -ne 1 ]; then
  echo "Usage: bin/migrate <db_path>" >&2
  exit 1
fi

DB_PATH="$1"

if [ ! -f "$DB_PATH" ]; then
  echo "Error: $DB_PATH not found" >&2
  exit 1
fi

# Verify old schema (auth table exists)
if ! sqlite3 "$DB_PATH" "SELECT 1 FROM auth LIMIT 1" >/dev/null 2>&1; then
  echo "Error: auth table not found — already migrated or not a valid old-schema DB" >&2
  exit 1
fi

# Backup
BAK_PATH="${DB_PATH}.bak"
cp "$DB_PATH" "$BAK_PATH"
echo "Backup: $BAK_PATH"

# Count records before migration
OLD_COUNTS=$(sqlite3 "$DB_PATH" "
  SELECT 'auth: ' || COUNT(*) FROM auth;
  SELECT 'channels: ' || COUNT(*) FROM channels;
  SELECT 'videos: ' || COUNT(*) FROM videos;
  SELECT 'groups: ' || COUNT(*) FROM groups;
  SELECT 'channel_groups: ' || COUNT(*) FROM channel_groups;
  SELECT 'sessions: ' || COUNT(*) FROM sessions;
")
echo "Old schema record counts:"
echo "$OLD_COUNTS"

# Create new DB alongside
NEW_PATH="${DB_PATH}.new"
rm -f "$NEW_PATH"

sqlite3 "$NEW_PATH" <<'SCHEMA'
PRAGMA journal_mode = WAL;
PRAGMA foreign_keys = OFF;

CREATE TABLE users (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    google_id TEXT NOT NULL,
    email TEXT NOT NULL,
    role TEXT NOT NULL DEFAULT 'member',
    rss_token TEXT,
    access_token TEXT,
    refresh_token TEXT,
    token_expires_at TEXT,
    created_at TEXT NOT NULL DEFAULT (datetime('now')),
    updated_at TEXT
);

CREATE TABLE channels (
    id TEXT PRIMARY KEY,
    title TEXT NOT NULL,
    thumbnail_url TEXT,
    upload_playlist_id TEXT,
    last_fetched_at TEXT,
    created_at TEXT NOT NULL
);

CREATE TABLE videos (
    id TEXT PRIMARY KEY,
    channel_id TEXT NOT NULL,
    title TEXT NOT NULL,
    thumbnail_url TEXT,
    published_at TEXT,
    duration TEXT,
    is_short INTEGER NOT NULL DEFAULT 0,
    is_livestream INTEGER NOT NULL DEFAULT 0,
    livestream_ended_at TEXT,
    fetched_at TEXT,
    FOREIGN KEY (channel_id) REFERENCES channels(id) ON DELETE CASCADE
);

CREATE TABLE user_channels (
    user_id INTEGER NOT NULL,
    channel_id TEXT NOT NULL,
    is_favorite INTEGER NOT NULL DEFAULT 0,
    show_livestreams INTEGER NOT NULL DEFAULT 0,
    created_at TEXT NOT NULL DEFAULT (datetime('now')),
    PRIMARY KEY (user_id, channel_id),
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
    FOREIGN KEY (channel_id) REFERENCES channels(id) ON DELETE CASCADE
);

CREATE TABLE user_videos (
    user_id INTEGER NOT NULL,
    video_id TEXT NOT NULL,
    is_hidden INTEGER NOT NULL DEFAULT 0,
    created_at TEXT NOT NULL DEFAULT (datetime('now')),
    PRIMARY KEY (user_id, video_id),
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
    FOREIGN KEY (video_id) REFERENCES videos(id) ON DELETE CASCADE
);

CREATE TABLE groups (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER NOT NULL,
    name TEXT NOT NULL,
    sort_order INTEGER NOT NULL DEFAULT 0,
    created_at TEXT NOT NULL,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

CREATE TABLE channel_groups (
    channel_id TEXT NOT NULL,
    group_id INTEGER NOT NULL,
    PRIMARY KEY (channel_id, group_id),
    FOREIGN KEY (channel_id) REFERENCES channels(id) ON DELETE CASCADE,
    FOREIGN KEY (group_id) REFERENCES groups(id) ON DELETE CASCADE
);

CREATE TABLE sessions (
    id TEXT PRIMARY KEY,
    user_id INTEGER NOT NULL,
    expires_at TEXT NOT NULL,
    created_at TEXT NOT NULL,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

CREATE UNIQUE INDEX idx_users_google_id ON users(google_id);
CREATE UNIQUE INDEX idx_users_rss_token ON users(rss_token);
CREATE INDEX idx_videos_published ON videos (published_at DESC);
CREATE INDEX idx_videos_channel ON videos (channel_id);
CREATE INDEX idx_user_channels_user ON user_channels(user_id);
CREATE INDEX idx_user_channels_favorite ON user_channels(user_id, is_favorite);
CREATE INDEX idx_user_videos_user ON user_videos(user_id);
CREATE INDEX idx_user_videos_hidden ON user_videos(user_id, is_hidden);
CREATE INDEX idx_groups_user ON groups(user_id);
SCHEMA

echo "New schema created: $NEW_PATH"

# Detect if old schema has is_favorite column on channels
HAS_IS_FAVORITE=$(sqlite3 "$BAK_PATH" "SELECT COUNT(*) FROM pragma_table_info('channels') WHERE name = 'is_favorite'")
if [ "$HAS_IS_FAVORITE" -eq 1 ]; then
  IS_FAVORITE_EXPR="c.is_favorite"
else
  IS_FAVORITE_EXPR="0"
fi

# Migrate data: attach old DB and insert
sqlite3 "$NEW_PATH" <<MIGRATE
ATTACH DATABASE '$BAK_PATH' AS old;

BEGIN TRANSACTION;

-- 1. auth -> users (first user = master, generate rss_token as UUID v4)
INSERT INTO users (id, google_id, email, role, rss_token, access_token, refresh_token, token_expires_at, created_at, updated_at)
SELECT id, google_id, email, 'master',
       lower(hex(randomblob(4))) || '-' || lower(hex(randomblob(2))) || '-4' || substr(lower(hex(randomblob(2))),2) || '-' || substr('89ab', abs(random()) % 4 + 1, 1) || substr(lower(hex(randomblob(2))),2) || '-' || lower(hex(randomblob(6))),
       access_token, refresh_token, token_expires_at,
       COALESCE(updated_at, datetime('now')), updated_at
FROM old.auth;

-- 2. channels (master data only)
INSERT INTO channels (id, title, thumbnail_url, upload_playlist_id, last_fetched_at, created_at)
SELECT id, title, thumbnail_url, upload_playlist_id, last_fetched_at, created_at
FROM old.channels;

-- 3. videos (master data only)
INSERT INTO videos (id, channel_id, title, thumbnail_url, published_at, duration, is_short, is_livestream, livestream_ended_at, fetched_at)
SELECT id, channel_id, title, thumbnail_url, published_at, duration, is_short, is_livestream, livestream_ended_at, fetched_at
FROM old.videos;

-- 4. user_channels (per-user preferences from old channels)
INSERT INTO user_channels (user_id, channel_id, is_favorite, show_livestreams, created_at)
SELECT u.id, c.id, $IS_FAVORITE_EXPR, c.show_livestreams, c.created_at
FROM old.channels c, users u;

-- 5. user_videos (hidden videos only)
INSERT INTO user_videos (user_id, video_id, is_hidden, created_at)
SELECT u.id, v.id, 1, COALESCE(v.fetched_at, datetime('now'))
FROM old.videos v, users u
WHERE v.is_hidden = 1;

-- 6. groups (assign to first user)
INSERT INTO groups (id, user_id, name, sort_order, created_at)
SELECT g.id, u.id, g.name, g.sort_order, g.created_at
FROM old.groups g, users u;

-- 7. channel_groups (unchanged)
INSERT INTO channel_groups (channel_id, group_id)
SELECT channel_id, group_id
FROM old.channel_groups;

-- 8. sessions (auth_id -> user_id)
INSERT INTO sessions (id, user_id, expires_at, created_at)
SELECT id, auth_id, expires_at, created_at
FROM old.sessions;

COMMIT;

DETACH DATABASE old;

-- Enable FK and verify
PRAGMA foreign_keys = ON;
PRAGMA integrity_check;
MIGRATE

echo ""

# Verify new DB
NEW_COUNTS=$(sqlite3 "$NEW_PATH" "
  SELECT 'users: ' || COUNT(*) FROM users;
  SELECT 'channels: ' || COUNT(*) FROM channels;
  SELECT 'videos: ' || COUNT(*) FROM videos;
  SELECT 'user_channels: ' || COUNT(*) FROM user_channels;
  SELECT 'user_videos: ' || COUNT(*) FROM user_videos;
  SELECT 'groups: ' || COUNT(*) FROM groups;
  SELECT 'channel_groups: ' || COUNT(*) FROM channel_groups;
  SELECT 'sessions: ' || COUNT(*) FROM sessions;
")
echo "New schema record counts:"
echo "$NEW_COUNTS"

# Swap: new -> target
mv "$NEW_PATH" "$DB_PATH"
# Also remove WAL/SHM from old DB if present
rm -f "${DB_PATH}-wal" "${DB_PATH}-shm"

echo ""
echo "Migration complete: $DB_PATH"
echo "Backup preserved: $BAK_PATH"
